    "hermes_cli/tools_config.py",
    "hermes_cli/gateway.py",
    "hermes_cli/status.py",
    "toolsets.py",
    "tools/send_message_tool.py",
    "cron/scheduler.py",
    "agent/prompt_builder.py"
  ],
  "templates": [
    "templates/config.qqbot.template.yaml",
    "templates/qqbot.env.template"
  ],
  "notes": [
    "source_snapshot 下是当前成功环境中的相关源码快照",
